+async def test_budget_counts_and_raises():
+    b = RequestBudget(max_requests=3)
+    await b.spend()          # 1
+    await b.spend(2)         # 3 (== limit, still OK)
+    assert b.spent == 3
+    with pytest.raises(BudgetExceeded) as ei:
+        await b.spend()      # 4 > 3
+    assert ei.value.limit == 3
+    assert ei.value.spent == 4
+
