#!/usr/bin/env python3
"""
Face OSINT — Instagram Face Search Toolkit

Commands:
  compare   <ref_image> <target_image>          Compare two face images
  search    <ref_image> <username> [options]    Recursive face-search through social graph
    --depth N    Graph depth (1=direct, 2=friends-of-friends, 3=...)
    --workers N  Parallel checks (default 3)
    --threshold X  Match threshold 0-1 (default 0.35)
  scrape    <username> [options]                Scrape followers/following lists
  pic       <username> [options]                Download profile picture
  list      <file>                              List results from a saved search

Global options (use before command):
  --cookie "<string>"     Instagram cookie string (env: IG_COOKIE)
  --cookies <file>        Path to cookies.txt file

Search depth examples:
  # Depth 1 — check followers/following of @target
  ./face-osint search ref.jpg target --depth 1

  # Depth 2 — check followers/following, then their friends too
  ./face-osint search ref.jpg target --depth 2 --workers 4

  # Depth 3 — deeper
  ./face-osint search ref.jpg target --depth 3 --threshold 0.3

  # With custom cookie
  ./face-osint --cookie "sessionid=..." search ref.jpg target --depth 2

Other examples:
  IG_COOKIE="sessionid=..." ./face-osint scrape username
  ./face-osint compare face1.jpg face2.jpg
"""
import sys, os, json, time, cv2, numpy as np, asyncio
from numpy.linalg import norm

BASE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, BASE)

from modules.instagram import Instagram, close_shared_browser
from modules.face import FaceEngine
from modules.search import BFSSearch
from modules.ratelimit import RateLimiter, RequestBudget
from modules import config

def resolve_cookie():
    if hasattr(resolve_cookie, "_cached"):
        return resolve_cookie._cached

    raw = None

    for i, arg in enumerate(sys.argv):
        if arg == "--cookies" and i + 1 < len(sys.argv):
            path = sys.argv[i + 1]
            if os.path.exists(path):
                with open(path) as f:
                    raw = f.read().strip()
                sys.argv.pop(i + 1)
                sys.argv.pop(i)
                break

    if raw is None:
        for i, arg in enumerate(sys.argv):
            if arg == "--cookie" and i + 1 < len(sys.argv):
                raw = sys.argv[i + 1]
                sys.argv.pop(i + 1)
                sys.argv.pop(i)
                break

    if raw is None:
        raw = os.environ.get("IG_COOKIE")

    if raw is None:
        raw = config.COOKIE_STRING

    resolve_cookie._cached = raw
    return raw

def cmd_compare(args):
    if len(args) < 2:
        print("Usage: face-osint compare <ref_image> <target_image>")
        return 1
    ref_path, target_path = args[0], args[1]

    engine = FaceEngine()
    ref_emb = engine.get_embedding_from_path(ref_path)
    target_emb = engine.get_embedding_from_path(target_path)

    if ref_emb is None:
        print("Error: No face detected in reference image.")
        return 1
    if target_emb is None:
        print("Error: No face detected in target image.")
        return 1

    sim = engine.compare(ref_emb, target_emb)
    pct = sim * 100
    threshold = config.SIM_THRESHOLD

    print(f"  Reference: {ref_path}")
    print(f"  Target:    {target_path}")
    print(f"  Similarity: {pct:.2f}%")
    print(f"  Threshold:  {threshold*100:.0f}%")
    print(f"  Match:      {'YES' if sim >= threshold else 'NO'}")
    return 0

async def _depth0_check(engine, ref_emb, username, cookie, threshold):
    async with Instagram(cookie) as ig:
        _, pic = await ig.get_profile_pic(username)
    if pic:
        sim = engine.compare_to_ref(pic, ref_emb)
        if sim is not None:
            print(f"  Similarity: {sim*100:.2f}%")
            if sim >= threshold:
                print(f"  >>> MATCH! @{username}")
        else:
            print("  No face detected in profile pic.")
    else:
        print("  Could not get profile pic.")

async def _scrape_user(username, cookie):
    followers_path = os.path.join(config.DATA_DIR, f"{username}_followers.json")
    following_path = os.path.join(config.DATA_DIR, f"{username}_following.json")

    async with Instagram(cookie) as ig:
        print("  Fetching followers...")
        followers = await ig.get_followers(username)
        if followers:
            json.dump(followers, open(followers_path, "w"))
            print(f"  Saved {len(followers)} followers")
        else:
            print("  Followers API rate-limited, try page-based scrape.")
            followers = []

        print("  Fetching following...")
        following = await ig.get_following(username)
        if following:
            json.dump(following, open(following_path, "w"))
            print(f"  Saved {len(following)} following")
        else:
            print("  Following API rate-limited, try page-based scrape.")
            following = []

    return followers, following

async def cmd_search(args):
    if len(args) < 2:
        print("Usage: face-osint search <ref_image> <instagram_username> [options]")
        print("Options:")
        print("  --depth N     Graph depth (0=user only, 1=followers/following, 2=their friends, ...)")
        print("  --workers N   Parallel workers (default 3)")
        print("  --threshold X Match threshold 0-1 (default 0.35)")
        print("  --no-cache    Re-scrape followers/following, ignore saved cache")
        print("  --rate N        Global read pace, requests/min (default 20; 0=off)")
        print("  --max-requests N  Per-run request budget (default 800)")
        print("  --max-expand N  Max accounts expanded per layer (default 15)")
        print("  --delay-min X / --delay-max X  Jittered inter-action delay seconds")
        print("")
        print("Examples:")
        print("  face-osint search ref.jpg target_user --depth 1")
        print("  face-osint search ref.jpg target_user --depth 3 --workers 5")
        return 1
    ref_path = args[0]
    username = args[1]
    cookie = resolve_cookie()

    workers = config.WORKERS
    threshold = config.SIM_THRESHOLD
    depth = 1
    no_cache = False
    rate = config.RATE_PER_MIN
    max_requests = config.MAX_REQUESTS
    max_expand = config.MAX_EXPANSIONS_PER_LAYER
    delay_min, delay_max = config.DELAY_RANGE

    i = 2
    while i < len(args):
        if args[i] == "--workers" and i + 1 < len(args):
            workers = int(args[i + 1]); i += 2
        elif args[i] == "--threshold" and i + 1 < len(args):
            threshold = float(args[i + 1]); i += 2
        elif args[i] == "--depth" and i + 1 < len(args):
            depth = int(args[i + 1]); i += 2
        elif args[i] == "--no-cache":
            no_cache = True; i += 1
        elif args[i] == "--rate" and i + 1 < len(args):
            rate = int(args[i + 1]); i += 2
        elif args[i] == "--max-requests" and i + 1 < len(args):
            max_requests = int(args[i + 1]); i += 2
        elif args[i] == "--max-expand" and i + 1 < len(args):
            max_expand = int(args[i + 1]); i += 2
        elif args[i] == "--delay-min" and i + 1 < len(args):
            delay_min = float(args[i + 1]); i += 2
        elif args[i] == "--delay-max" and i + 1 < len(args):
            delay_max = float(args[i + 1]); i += 2
        else:
            i += 1

    if not os.path.exists(ref_path):
        print(f"Error: Reference image not found: {ref_path}")
        return 1

    print("Initializing face engine...")
    engine = FaceEngine()
    ref_emb = engine.get_embedding_from_path(ref_path)
    if ref_emb is None:
        print("Error: No face detected in reference image.")
        return 1
    ref_img = cv2.imread(ref_path)
    print(f"  Reference: {ref_img.shape[1]}x{ref_img.shape[0]}")
    print(f"  Threshold: {threshold*100:.0f}%")
    print(f"  Workers:   {workers}")
    print(f"  Depth:     {depth}")

    if depth == 0:
        print(f"\nChecking @{username}...")
        await _depth0_check(engine, ref_emb, username, cookie, threshold)
        await close_shared_browser()
        return 0

    followers_path = os.path.join(config.DATA_DIR, f"{username}_followers.json")
    following_path = os.path.join(config.DATA_DIR, f"{username}_following.json")

    if no_cache or not os.path.exists(followers_path) or not os.path.exists(following_path):
        if no_cache:
            print(f"\n--no-cache: re-scraping @{username}...")
        else:
            print(f"\nScraping followers/following of @{username}...")
        followers, following = await _scrape_user(username, cookie)
    else:
        followers = json.load(open(followers_path))
        following = json.load(open(following_path))
        print(f"  Loaded {len(followers)} followers, {len(following)} following from cache")

    layer0 = list(dict.fromkeys(followers + following))
    print(f"\nLayer 0: {len(layer0)} unique accounts")
    print(f"Searching with {workers} parallel workers...")

    limiter = RateLimiter(rate, jitter_range=(delay_min, delay_max))
    budget = RequestBudget(max_requests)
    config.MAX_EXPANSIONS_PER_LAYER = max_expand   # honor CLI override

    searcher = BFSSearch(ref_path, cookie_string=cookie, workers=workers,
                         face_engine=engine, ref_emb=ref_emb,
                         rate_limiter=limiter, budget=budget)
    t0 = time.time()
    results = await searcher.search(layer0, depth=depth)
    elapsed = time.time() - t0

    if searcher.stop_reason:
        print(f"\n  STOPPED early (safety): {searcher.stop_reason}")

    print(f"\nDone in {elapsed:.0f}s")
    print(f"Faces detected: {len(searcher.results)}")

    top = searcher.get_top(20)
    print(f"\nTop 20:")
    for u, s in top:
        mark = " <<<" if s >= threshold else ""
        print(f"  @{u}: {s*100:.1f}%{mark}")

    if searcher.found_data[0]:
        u, s = searcher.found_data[0]
        print(f"\n{'='*55}")
        print(f"  FOUND! @{u}  |  {s*100:.2f}%")
        print(f"  https://instagram.com/{u}")
        print(f"{'='*55}")
    else:
        print(f"\nNot found. Best: {top[0][0] if top else 'N/A'} at {top[0][1]*100:.1f}%" if top else "")

    saved = searcher.save_results()
    print(f"\nResults saved: {saved}")
    await close_shared_browser()
    return 0

async def cmd_scrape(args):
    if len(args) < 1:
        print("Usage: face-osint scrape <username>")
        return 1
    username = args[0]
    cookie = resolve_cookie()

    async with Instagram(cookie) as ig:
        print(f"Scraping @{username}...")

        followers = await ig.get_followers(username)
        if followers:
            path = os.path.join(config.DATA_DIR, f"{username}_followers.json")
            json.dump(followers, open(path, "w"))
            print(f"  Followers: {len(followers)} -> {path}")

        following = await ig.get_following(username)
        if following:
            path = os.path.join(config.DATA_DIR, f"{username}_following.json")
            json.dump(following, open(path, "w"))
            print(f"  Following: {len(following)} -> {path}")
    await close_shared_browser()
    return 0

async def cmd_pic(args):
    if len(args) < 1:
        print("Usage: face-osint pic <username>")
        return 1
    username = args[0]
    cookie = resolve_cookie()

    async with Instagram(cookie) as ig:
        url, pic = await ig.get_profile_pic(username)

    if pic:
        path = os.path.join(config.DATA_DIR, f"{username}_profile.jpg")
        with open(path, "wb") as f:
            f.write(pic)
        print(f"  Downloaded: {path} ({len(pic)} bytes)")
        print(f"  URL: {url}")
    else:
        print("  Could not download profile picture.")
    await close_shared_browser()
    return 0

def cmd_list(args):
    if len(args) < 1:
        path = os.path.join(config.RESULTS_DIR, "face_search_result.json")
    else:
        path = args[0]

    if not os.path.exists(path):
        print(f"File not found: {path}")
        return 1

    data = json.load(open(path))
    print(f"Total checked: {data.get('total_checked', '?')}")
    print(f"Faces detected: {data.get('total_faces', '?')}")
    print(f"Match: {'YES' if data.get('found') else 'NO'}")

    if data.get("match"):
        m = data["match"]
        print(f"  Found: @{m['username']} at {m['similarity']}%")

    print(f"\nTop matches:")
    for item in data.get("top_50", [])[:20]:
        print(f"  @{item['username']}: {item['similarity']:.1f}%")
    return 0

def main():
    resolve_cookie()
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        print(__doc__)
        return 0 if sys.argv[1:] else 1

    cmd = sys.argv[1]
    args = sys.argv[2:]

    sync_cmds = {"compare": cmd_compare, "list": cmd_list}
    async_cmds = {"search": cmd_search, "scrape": cmd_scrape, "pic": cmd_pic}
    commands = {**sync_cmds, **async_cmds}

    if cmd not in commands:
        print(f"Unknown command: {cmd}")
        print(f"Available: {', '.join(commands.keys())}")
        return 1

    if cmd in async_cmds:
        return asyncio.run(commands[cmd](args))
    else:
        return commands[cmd](args)

if __name__ == "__main__":
    sys.exit(main())
